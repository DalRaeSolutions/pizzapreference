{
    "tenant-mode": "dedicated",
    "scopes": [
        {
            "name": "$XSAPPNAME.pizzaeater",
            "description": "Records own pizza preference"
        },
        {
            "name": "$XSAPPNAME.pizzaorderer",
            "description": "Places the group pizza order"
        }
    ],
    "attributes": [
        {
            "name": "email",
            "description": "User email address",
            "valueType": "string"
        },
        {
            "name": "displayName",
            "description": "User display name",
            "valueType": "string"
        },
        {
            "name": "department",
            "description": "User department",
            "valueType": "string"
        }
    ],
    "role-templates": [
        {
            "name": "pizzaeater",
            "description": "Pizza Eater",
            "scope-references": [
                "$XSAPPNAME.pizzaeater"
            ],
            "attribute-references": [
                "email",
                "displayName",
                "department"
            ]
        },
        {
            "name": "pizzaorderer",
            "description": "Pizza Orderer",
            "scope-references": [
                "$XSAPPNAME.pizzaorderer"
            ],
            "attribute-references": [
                "email",
                "displayName",
                "department"
            ]
        }
    ],
    "role-collections": [
        {
            "name": "pizzaeater",
            "description": "Pizza Eater",
            "role-template-references": [
                "$XSAPPNAME.pizzaeater"
            ]
        },
        {
            "name": "pizzaorderer",
            "description": "Pizza Orderer",
            "role-template-references": [
                "$XSAPPNAME.pizzaorderer"
            ]
        }
    ]
}
