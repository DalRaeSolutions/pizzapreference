{
    "name": "pizzapreference",
    "version": "0.0.1",
    "private": true,
    "description": "",
    "keywords": [
        "ui5",
        "openui5",
        "sapui5"
    ],
    "main": "webapp/index.html",
    "scripts": {
        "build": "npm run clean && npm i && ui5 build --include-task=generateCachebusterInfo && npm run zip",
        "zip": "cd dist && npx bestzip ../pizzapreference-content.zip *",
        "clean": "npx rimraf pizzapreference-content.zip dist",
        "start": "fiori run --open 'index.html'",
        "start-local": "fiori run --config ./ui5-local.yaml --open 'index.html'",
        "start-noflp": "fiori run --open 'index.html'",
        "deploy": "fiori verify",
        "deploy-config": "fiori add deploy-config",
        "build:cf": "ui5 build preload --clean-dest --config ui5-deploy.yaml --include-task=generateCachebusterInfo"
    },
    "devDependencies": {
        "@sap/ui5-builder-webide-extension": "^1.1.9",
        "@sap/ux-ui5-tooling": "^1.22.0",
        "@ui5/cli": "^4.0.51",
        "bestzip": "^2.2.3",
        "mbt": "^1.2.45",
        "rimraf": "^6.1.3",
        "ui5-task-zipper": "^3.6.0"
    },
    "ui5": {
        "dependencies": [
            "@sap/ux-ui5-tooling",
            "@sap/ui5-builder-webide-extension",
            "ui5-task-zipper",
            "mbt"
        ]
    },
    "overrides": {
        "@xmldom/xmldom": "^0.9.9",
        "js-yaml": "^4.1.1",
        "lodash": "^4.18.1"
    }
}
