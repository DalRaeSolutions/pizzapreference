<mvc:View
    controllerName="com.dalraesolutions.pizzapreference.pizzapreference.controller.List"
    xmlns:mvc="sap.ui.core.mvc"
    displayBlock="true"
    xmlns="sap.m"
    xmlns:core="sap.ui.core"
>
    <Shell id="shell">
        <App id="app">
            <pages>
                <Page id="apppage" title="{i18n>listTitle}">
                    <content>

                        <IconTabBar id="idMainTabs" expandable="false" class="sapUiResponsiveContentPadding">
                            <items>

                                <IconTabFilter
                                    id="idMyPreferenceTab"
                                    text="My Preference"
                                    icon="sap-icon://meal"
                                    visible="{viewModel>/isEater}">

                                    <VBox class="sapUiMediumMargin" visible="{= !${viewModel>/preference} }">
                                        <Text text="You have no pizza preference set." class="sapUiSmallMarginBottom" />
                                        <Button
                                            text="Add Pizza Preference"
                                            icon="sap-icon://add"
                                            type="Emphasized"
                                            press="onOpenPreferenceDialog"
                                            width="220px"
                                            visible="{viewModel>/isEater}" />
                                    </VBox>

                                    <HBox class="sapUiMediumMargin" visible="{= !!${viewModel>/preference} }">
                                        <core:Icon size="3rem" src="sap-icon://meal" class="sapUiSmallMarginEnd sapUiSmallMarginTop" />
                                        <VBox width="70%">
                                            <Title text="{viewModel>/preference/pizza/name}" level="H3" />
                                            <Label text="{viewModel>/preference/pizza/description}" />
                                            <Label text="Notes: {viewModel>/preference/notes}" class="sapUiTinyMarginTop" />
                                            <Label text="Last updated: { path: 'viewModel>/preference/modifiedAt', formatter: '.formatter.date' }" />
                                        </VBox>
                                        <VBox class="sapUiSmallMarginBegin" visible="{viewModel>/isEater}">
                                            <Button
                                                text="Edit"
                                                icon="sap-icon://edit"
                                                press="onOpenPreferenceDialog"
                                                width="110px"
                                                class="sapUiTinyMarginBottom" />
                                            <Button
                                                text="Delete"
                                                icon="sap-icon://delete"
                                                type="Reject"
                                                press="onDeletePreference"
                                                width="110px" />
                                        </VBox>
                                    </HBox>

                                </IconTabFilter>

                                <IconTabFilter
                                    id="idTeamOrderTab"
                                    text="Team Order"
                                    icon="sap-icon://group"
                                    visible="{viewModel>/isOrderer}">

                                    <VBox class="sapUiSmallMargin">

                                        <HBox justifyContent="SpaceBetween" alignItems="Center" class="sapUiSmallMarginBottom">
                                            <Title text="My Pizza Orders" level="H3" />
                                            <Button
                                                text="New Order from Meeting"
                                                icon="sap-icon://group"
                                                type="Emphasized"
                                                press="onOpenCreateOrderDialog" />
                                        </HBox>

                                        <VBox class="sapUiMediumMargin" visible="{= ${viewModel>/orders}.length === 0 }">
                                            <Text text="You haven't created any orders yet. Paste a meeting attendee list to get started." />
                                        </VBox>

                                        <List
                                            id="idOrdersList"
                                            items="{ path: 'viewModel>/orders' }"
                                            visible="{= ${viewModel>/orders}.length > 0 }"
                                            noDataText="No orders recorded">
                                            <CustomListItem type="Active" press="onOrderPress">
                                                <HBox class="sapUiSmallMargin" alignItems="Center">
                                                    <core:Icon size="2rem" src="sap-icon://group" class="sapUiSmallMarginEnd" />
                                                    <VBox width="60%">
                                                        <Title text="{viewModel>title}" level="H4" />
                                                        <Label text="{ path: 'viewModel>occurredAt', formatter: '.formatter.date' }" />
                                                        <Label text="{ parts: ['viewModel>matchedCount', 'viewModel>unmatchedCount'], formatter: '.formatter.orderSubtitle' }" />
                                                    </VBox>
                                                    <VBox width="25%" alignItems="Center" justifyContent="Center">
                                                        <ObjectNumber
                                                            number="{viewModel>participantCount}"
                                                            unit="attendees"
                                                            emphasized="true" />
                                                    </VBox>
                                                    <VBox width="15%" alignItems="End">
                                                        <Button
                                                            icon="sap-icon://delete"
                                                            type="Reject"
                                                            press="onDeleteOrder"
                                                            tooltip="Delete order" />
                                                    </VBox>
                                                </HBox>
                                            </CustomListItem>
                                        </List>

                                    </VBox>

                                </IconTabFilter>

                            </items>
                        </IconTabBar>

                    </content>
                </Page>
            </pages>
        </App>
    </Shell>
</mvc:View>
