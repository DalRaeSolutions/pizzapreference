<core:FragmentDefinition
    xmlns="sap.m"
    xmlns:core="sap.ui.core"
    xmlns:f="sap.ui.layout.form"
>
    <Dialog
        id="idCreateOrderDialog"
        title="New Pizza Order"
        contentWidth="600px">
        <content>
            <f:SimpleForm
                id="idCreateOrderForm"
                editable="true"
                layout="ResponsiveGridLayout"
                labelSpanXL="3"
                labelSpanL="3"
                labelSpanM="3"
                labelSpanS="12"
                adjustLabelSpan="false"
                emptySpanXL="1"
                emptySpanL="1"
                emptySpanM="1"
                emptySpanS="0"
                columnsXL="1"
                columnsL="1"
                columnsM="1"
                singleContainerFullSize="false">
                <f:content>

                    <Label text="Title" required="true" />
                    <Input
                        id="idCreateOrderTitle"
                        value="{createOrderModel>/title}"
                        placeholder="e.g. Friday lunch — Finance stand-up" />

                    <Label text="When" required="true" />
                    <DatePicker
                        id="idCreateOrderDate"
                        value="{createOrderModel>/occurredAt}"
                        valueFormat="yyyy-MM-dd"
                        displayFormat="long" />

                    <Label text="Attendees" required="true" />
                    <TextArea
                        id="idCreateOrderPaste"
                        value="{createOrderModel>/paste}"
                        rows="8"
                        growing="false"
                        placeholder="Paste from Outlook / Teams / email — display names and emails both work" />

                </f:content>
            </f:SimpleForm>
        </content>
        <beginButton>
            <Button text="Create Order" type="Emphasized" press="onSaveCreateOrder" />
        </beginButton>
        <endButton>
            <Button text="Cancel" press="onCancelCreateOrder" />
        </endButton>
    </Dialog>
</core:FragmentDefinition>
